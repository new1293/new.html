<script>
var currentUser=null,chartInst=null,scoreTargetId=null;
var SESSION_KEY='wp_session',CREDS_KEY='wp_creds',WORKERS_KEY='wp_workers',TASKS_KEY='wp_tasks';
var ONE_DAY=24*60*60*1000;

/* ---- STORAGE ---- */
function ss(u){try{localStorage.setItem(SESSION_KEY,JSON.stringify({user:u,t:Date.now()}))}catch(e){}}
function ls(){try{var r=localStorage.getItem(SESSION_KEY);if(!r)return null;var s=JSON.parse(r);if(Date.now()-s.t>ONE_DAY){localStorage.removeItem(SESSION_KEY);return null}return s.user}catch(e){return null}}
function cs(){try{localStorage.removeItem(SESSION_KEY)}catch(e){}}
function sc(e,p,u){try{localStorage.setItem(CREDS_KEY,JSON.stringify({email:e,pass:p,userData:u}))}catch(e2){}}
function lc(){try{var r=localStorage.getItem(CREDS_KEY);return r?JSON.parse(r):null}catch(e){return null}}
function gW(){try{var r=localStorage.getItem(WORKERS_KEY);return r?JSON.parse(r):[]}catch(e){return[]}}
function sW(l){try{localStorage.setItem(WORKERS_KEY,JSON.stringify(l))}catch(e){}}
function gT(){try{var r=localStorage.getItem(TASKS_KEY);return r?JSON.parse(r):[]}catch(e){return[]}}
function sT(l){try{localStorage.setItem(TASKS_KEY,JSON.stringify(l))}catch(e){}}

/* ---- HELPERS ---- */
function calcScore(w){return(w.doneTasks||0)*10+(w.managerScore||0)}
function stars(s){var p=Math.min(s/200,1),f=Math.round(p*5),h='';for(var i=0;i<5;i++)h+='<span style="color:'+(i<f?'#f59e0b':'#334155')+'">&#9733;</span>';return h}
function el(id){return document.getElementById(id)}
function showErr(m){el('err-msg').textContent=m;el('err-msg').style.display='block'}

/* ---- LOGIN / REGISTER ---- */
function loginTab(t){
  document.querySelectorAll('.tab-btn').forEach(function(b,i){b.classList.toggle('active',(t==='login'&&i===0)||(t==='reg'&&i===1))});
  el('lf-login').classList.toggle('visible',t==='login');
  el('lf-reg').classList.toggle('visible',t==='reg');
  el('err-msg').style.display='none';
}
function selChip(e){document.querySelectorAll('.chip').forEach(function(c){c.classList.remove('selected')});e.classList.add('selected')}

function doLogin(){
  var email=el('l-email').value.trim(),pass=el('l-pass').value;
  if(!email||!pass){showErr('Email va parol kiriting!');return}
  var c=lc();
  if(!c){showErr("Avval ro&#39;yxatdan o&#39;ting!");return}
  if(c.email!==email){showErr('Email topilmadi!');return}
  if(c.pass!==pass){showErr("Parol noto&#39;g&#39;ri!");return}
  currentUser=c.userData;ss(currentUser);enterApp();
}

function doRegister(){
  var name=el('r-name').value.trim(),sname=el('r-sname').value.trim();
  var email=el('r-email').value.trim(),phone=el('r-phone').value.trim();
  var pass=el('r-pass').value;
  var roleEl=document.querySelector('.chip.selected');
  var role=roleEl?roleEl.textContent.trim():'Ishchi';
  if(!name||!email){showErr('Ism va email majburiy!');return}
  if(!pass||pass.length<4){showErr("Parol kamida 4 ta belgi bo&#39;lsin!");return}
  var av=(name[0]+(sname[0]||'')).toUpperCase();
  currentUser={name:name+' '+sname,email:email,role:role,phone:phone,avatar:av};
  sc(email,pass,currentUser);ss(currentUser);
  var ws=gW();
  if(!ws.some(function(w){return w.email===email})){
    ws.push({id:Date.now(),name:name+' '+sname,phone:phone,role:role,email:email,avatar:av,doneTasks:0,managerScore:0});
    sW(ws);
  }
  enterApp();
}

function enterApp(){
  el('page-login').classList.remove('active');
  el('page-app').classList.add('active');
  updateUI();renderAll();setTimeout(initChart,100);
}

function doLogout(){
  cs();currentUser=null;
  if(chartInst){chartInst.destroy();chartInst=null}
  el('page-app').classList.remove('active');
  el('page-login').classList.add('active');
  el('l-email').value='';el('l-pass').value='';
}

/* ---- UI UPDATE ---- */
function updateUI(){
  if(!currentUser)return;
  var u=currentUser;
  ['sb-av','tb-av','ph-av'].forEach(function(id){el(id).textContent=u.avatar||'U'});
  el('sb-name').textContent=u.name;
  el('sb-role').textContent=u.role;
  el('tb-sub').textContent='Xush kelibsiz, '+u.name+'!';
  el('ph-name').textContent=u.name;
  el('ph-role').textContent=u.role;
  el('ph-email').textContent=u.email;
  el('ph-phone').textContent=u.phone||'';
  var p=u.name.split(' ');
  el('pf-name').value=p[0]||'';el('pf-sname').value=p[1]||'';
  el('pf-email').value=u.email;el('pf-phone').value=u.phone||'';
  el('nav-workers').style.display=(u.role==='Menejer')?'flex':'none';
}

/* ---- RENDER ALL ---- */
function renderAll(){
  var ws=gW();
  el('stat-workers').textContent=ws.length;
  el('workers-count').textContent=ws.length;
  renderWorkersTable(ws);renderDashWorkers(ws);renderRating(ws);
  updateMyStats(ws);updateTasksBadge();
}

function renderWorkersTable(ws){
  var tb=el('workers-table-body');if(!tb)return;
  tb.innerHTML='';
  ws.forEach(function(w,i){
    var sc=calcScore(w);
    var tr=document.createElement('tr');
    var safeId=w.id;
    tr.innerHTML='<td>'+(i+1)+'</td>'
      +'<td><div style="display:flex;align-items:center;gap:10px;">'
      +'<div style="width:32px;height:32px;border-radius:50%;background:linear-gradient(135deg,#3b82f6,#8b5cf6);display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:600;color:white;">'+w.avatar+'</div>'
      +w.name+'</div></td>'
      +'<td><span class="badge b-active">'+w.role+'</span></td>'
      +'<td style="color:var(--text2)">'+(w.phone||'—')+'</td>'
      +'<td><span class="score-badge">'+sc+'</span></td>'
      +'<td>'+stars(sc)+'</td>'
      +'<td><div style="display:flex;gap:6px;">'
      +'<button class="btn-score" data-sid="'+safeId+'">Ball</button>'
      +'<button class="btn-del" data-did="'+safeId+'">O&#39;chir</button>'
      +'</div></td>';
    tb.appendChild(tr);
  });
  // attach events after rendering
  tb.querySelectorAll('[data-sid]').forEach(function(btn){
    var id=parseInt(btn.getAttribute('data-sid'));
    var w=ws.find(function(x){return x.id===id});
    btn.onclick=function(){openScoreModal(id,w?w.name:'')};
  });
  tb.querySelectorAll('[data-did]').forEach(function(btn){
    var id=parseInt(btn.getAttribute('data-did'));
    btn.onclick=function(){deleteWorker(id)};
  });
}

function renderDashWorkers(ws){
  var tb=el('dash-workers-body');if(!tb)return;
  tb.innerHTML='';
  ws.slice().sort(function(a,b){return calcScore(b)-calcScore(a)}).slice(0,5).forEach(function(w){
    var sc=calcScore(w);
    var tr=document.createElement('tr');
    tr.innerHTML='<td>'+w.name+'</td><td>'+w.role+'</td>'
      +'<td><div style="display:flex;align-items:center;gap:4px;">'+stars(sc)+'<span style="font-size:12px;color:var(--text3);margin-left:4px;">'+sc+'</span></div></td>';
    tb.appendChild(tr);
  });
}

function renderRating(ws){
  var e=el('rating-list');if(!e)return;
  var sorted=ws.slice().sort(function(a,b){return calcScore(b)-calcScore(a)});
  var maxSc=sorted.length>0?calcScore(sorted[0]):1;
  if(sorted.length===0){e.innerHTML='<div style="text-align:center;color:var(--text3);padding:2rem;">Hali ishchi yo&#39;q</div>';return}
  var h='';
  sorted.forEach(function(w,i){
    var sc=calcScore(w);
    var pct=maxSc>0?Math.round(sc/maxSc*100):0;
    var rc=i===0?'gold':i===1?'silver':i===2?'bronze':'';
    h+='<div style="display:flex;align-items:center;gap:14px;padding:14px;background:rgba(255,255,255,0.03);border-radius:12px;border:1px solid var(--border);margin-bottom:6px;">'
      +'<div class="rank-num '+rc+'" style="width:28px;text-align:center;font-size:16px;font-weight:700;">'+(i+1)+'</div>'
      +'<div style="width:38px;height:38px;border-radius:50%;background:linear-gradient(135deg,#3b82f6,#8b5cf6);display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:600;color:white;flex-shrink:0;">'+w.avatar+'</div>'
      +'<div style="flex:1;min-width:0;"><div style="font-size:14px;font-weight:500;color:var(--text);">'+w.name+'</div>'
      +'<div style="font-size:12px;color:var(--text3);margin-top:2px;">'+w.role+' &bull; Vazifa: '+(w.doneTasks||0)+' &bull; Menejer: '+(w.managerScore||0)+'</div></div>'
      +'<div style="width:120px;height:6px;background:rgba(255,255,255,.08);border-radius:3px;overflow:hidden;"><div style="height:100%;width:'+pct+'%;background:linear-gradient(90deg,#f59e0b,#f97316);border-radius:3px;"></div></div>'
      +'<span class="score-badge">'+sc+' ball</span>'
      +'<div>'+stars(sc)+'</div>'
      +'</div>';
  });
  e.innerHTML=h;
}

function updateMyStats(ws){
  if(!currentUser)return;
  var me=ws.find(function(w){return w.email===currentUser.email});
  if(me){
    var sc=calcScore(me);
    var sorted=ws.slice().sort(function(a,b){return calcScore(b)-calcScore(a)});
    var rank=sorted.findIndex(function(w){return w.email===currentUser.email})+1;
    el('my-tasks-count').textContent=me.doneTasks||0;
    el('my-score').textContent=sc;
    el('my-rank').textContent='#'+rank;
  }
}

/* ---- WORKERS ---- */
function openAddModal(){el('modal-add').classList.add('open')}
function closeModal(id){el(id).classList.remove('open')}

function addWorker(){
  var name=el('m-name').value.trim(),sname=el('m-sname').value.trim();
  var phone=el('m-phone').value.trim(),role=el('m-role').value;
  if(!name){alert('Ism kiriting!');return}
  var av=(name[0]+(sname[0]||'')).toUpperCase();
  var ws=gW();
  ws.push({id:Date.now(),name:name+' '+sname,phone:phone,role:role,email:'',avatar:av,doneTasks:0,managerScore:0});
  sW(ws);closeModal('modal-add');
  el('m-name').value='';el('m-sname').value='';el('m-phone').value='';
  renderAll();
}

function deleteWorker(id){
  if(!confirm("Ishchini o&#39;chirishni tasdiqlaysizmi?"))return;
  sW(gW().filter(function(w){return w.id!==id}));renderAll();
}

function openScoreModal(id,name){
  scoreTargetId=id;
  el('score-worker-name').textContent=(name||'Ishchi')+' uchun ball kiriting';
  var w=gW().find(function(x){return x.id===id});
  el('m-score').value=w?w.managerScore:0;
  el('m-score-note').value='';
  el('modal-score').classList.add('open');
}

function giveScore(){
  var v=parseInt(el('m-score').value)||0;
  if(v<0||v>100){alert("Ball 0-100 oralig&#39;ida bo&#39;lsin!");return}
  sW(gW().map(function(w){return w.id===scoreTargetId?Object.assign({},w,{managerScore:v}):w}));
  closeModal('modal-score');renderAll();
}

/* ---- TASKS ---- */
function updateTasksBadge(){
  var tasks=gT(),badge=el('tasks-badge');
  if(!badge)return;
  if(currentUser&&currentUser.role==='Menejer'){
    badge.textContent=tasks.filter(function(t){return t.status==='pending'}).length;
  } else {
    var ws=gW(),me=ws.find(function(w){return currentUser&&w.email===currentUser.email});
    badge.textContent=me?tasks.filter(function(t){return t.workerId===me.id&&t.status==='pending'}).length:0;
  }
}

function openTaskModal(){
  var ws=gW(),sel=el('t-worker');
  sel.innerHTML='';
  ws.forEach(function(w){
    var opt=document.createElement('option');
    opt.value=w.id;opt.textContent=w.name+' ('+w.role+')';
    sel.appendChild(opt);
  });
  var d=new Date();d.setDate(d.getDate()+3);
  el('t-date').value=d.toISOString().split('T')[0];
  el('t-title').value='';el('t-desc').value='';
  el('modal-task').classList.add('open');
}

function assignTask(){
  var title=el('t-title').value.trim(),desc=el('t-desc').value.trim();
  var wid=parseInt(el('t-worker').value),pri=el('t-priority').value,date=el('t-date').value;
  if(!title){alert('Vazifa nomini kiriting!');return}
  var w=gW().find(function(x){return x.id===wid});
  if(!w){alert('Ishchi topilmadi!');return}
  var tasks=gT();
  tasks.push({id:Date.now(),title:title,desc:desc,workerId:wid,workerName:w.name,workerAvatar:w.avatar,priority:pri,dueDate:date,status:'pending',assignedBy:currentUser?currentUser.name:'Menejer'});
  sT(tasks);closeModal('modal-task');renderTasks();updateTasksBadge();
}

function completeTask(id){
  var tasks=gT(),task=tasks.find(function(t){return t.id===id});
  if(!task)return;
  sT(tasks.map(function(t){return t.id===id?Object.assign({},t,{status:'done'}):t}));
  sW(gW().map(function(w){return w.id===task.workerId?Object.assign({},w,{doneTasks:(w.doneTasks||0)+1}):w}));
  renderTasks();renderAll();
}

function deleteTask(id){
  if(!confirm("Vazifani o&#39;chirishni tasdiqlaysizmi?"))return;
  sT(gT().filter(function(t){return t.id!==id}));renderTasks();updateTasksBadge();
}

function renderTasks(){
  var tasks=gT(),isM=currentUser&&currentUser.role==='Menejer';
  el('tasks-manager-view').style.display=isM?'block':'none';
  el('tasks-worker-view').style.display=isM?'none':'block';
  var prMap={high:'<span class="tp tp-h">Shoshilinch</span>',mid:'<span class="tp tp-m">O&#39;rta</span>',low:'<span class="tp tp-l">Oddiy</span>'};

  if(isM){
    var tb=el('all-tasks-body');if(!tb)return;
    tb.innerHTML='';
    var done=tasks.filter(function(t){return t.status==='done'}).length;
    el('tasks-stats').textContent='Jami: '+tasks.length+' | Bajarilgan: '+done+' | Kutilmoqda: '+(tasks.length-done);
    tasks.forEach(function(t){
      var isDone=t.status==='done';
      var tr=document.createElement('tr');
      tr.innerHTML='<td><div style="font-weight:500;">'+t.title+'</div>'+(t.desc?'<div style="font-size:12px;color:var(--text3);">'+t.desc+'</div>':'')+'</td>'
        +'<td><div style="display:flex;align-items:center;gap:8px;"><div style="width:28px;height:28px;border-radius:50%;background:linear-gradient(135deg,#3b82f6,#8b5cf6);display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:600;color:white;">'+t.workerAvatar+'</div>'+t.workerName+'</div></td>'
        +'<td>'+(prMap[t.priority]||t.priority)+'</td>'
        +'<td style="font-size:13px;color:var(--text2);">'+(t.dueDate||'—')+'</td>'
        +'<td>'+(isDone?'<span class="badge b-active">&#10003; Bajarildi</span>':'<span class="badge b-pending">Kutilmoqda</span>')+'</td>'
        +'<td><div style="display:flex;gap:6px;" data-tid="'+t.id+'" data-done="'+isDone+'"></div></td>';
      tb.appendChild(tr);
      var btnWrap=tr.querySelector('[data-tid]');
      if(!isDone){var b1=document.createElement('button');b1.className='btn-score';b1.textContent='Bajarildi';(function(tid){b1.onclick=function(){completeTask(tid)}})(t.id);btnWrap.appendChild(b1);}
      var b2=document.createElement('button');b2.className='btn-del';b2.textContent="O&#39;chir";(function(tid){b2.onclick=function(){deleteTask(tid)}})(t.id);btnWrap.appendChild(b2);
    });
  } else {
    var ws=gW(),me=ws.find(function(w){return currentUser&&w.email===currentUser.email});
    var myT=me?tasks.filter(function(t){return t.workerId===me.id}):[];
    var pend=myT.filter(function(t){return t.status==='pending'});
    var done2=myT.filter(function(t){return t.status==='done'});
    el('my-pending-count').textContent=pend.length+' ta';
    el('my-done-count').textContent=done2.length+' ta';

    function card(t,isDone){
      var d=document.createElement('div');
      d.style.cssText='padding:14px;border-bottom:1px solid var(--border)';
      d.innerHTML='<div style="display:flex;justify-content:space-between;align-items:flex-start;gap:10px;">'
        +'<div style="flex:1;"><div style="font-size:14px;font-weight:500;'+(isDone?'text-decoration:line-through;color:var(--text3)':'color:var(--text)')+';">'+t.title+'</div>'
        +(t.desc?'<div style="font-size:12px;color:var(--text3);margin-top:3px;">'+t.desc+'</div>':'')+'</div>'
        +(prMap[t.priority]||'')+'</div>'
        +'<div style="display:flex;justify-content:space-between;align-items:center;margin-top:8px;">'
        +'<span style="font-size:12px;color:var(--text3);">Muddat: '+(t.dueDate||'—')+' &bull; '+t.assignedBy+'</span>'
        +(isDone?'<span style="font-size:12px;color:var(--green);">&#10003; Bajarildi</span>':'<span class="pending-btn"></span>')
        +'</div>';
      if(!isDone){
        var btn=d.querySelector('.pending-btn');
        var b=document.createElement('button');b.className='btn-score';b.style.fontSize='12px';b.textContent='✓ Bajardim';
        (function(tid){b.onclick=function(){completeTask(tid)}})(t.id);
        btn.appendChild(b);
      }
      return d;
    }

    var pe=el('my-tasks-pending'),de=el('my-tasks-done');
    pe.innerHTML='';de.innerHTML='';
    if(pend.length){pend.forEach(function(t){pe.appendChild(card(t,false))})}
    else pe.innerHTML='<div style="text-align:center;color:var(--text3);padding:2rem;">Hozircha vazifa yo&#39;q</div>';
    if(done2.length){done2.forEach(function(t){de.appendChild(card(t,true))})}
    else de.innerHTML='<div style="text-align:center;color:var(--text3);padding:2rem;">Hali bajarilmagan</div>';
  }
}

/* ---- NAVIGATION ---- */
function showSub(id,btn){
  document.querySelectorAll('.sub-page').forEach(function(p){p.classList.remove('active')});
  el('sp-'+id).classList.add('active');
  document.querySelectorAll('.nav-item').forEach(function(b){b.classList.remove('active')});
  if(btn)btn.classList.add('active');
  var titles={dashboard:'Dashboard',workers:'Ishchilar',rating:'Reyting',tasks:'Vazifalar',profile:'Profil'};
  el('tb-title').textContent=titles[id]||id;
  if(id==='rating'||id==='workers')renderAll();
  if(id==='tasks'){renderTasks();updateTasksBadge();}
}

function showPTab(id,btn){
  document.querySelectorAll('.ptab-content').forEach(function(p){p.classList.remove('active')});
  el(id).classList.add('active');
  document.querySelectorAll('.ptab').forEach(function(b){b.classList.remove('active')});
  btn.classList.add('active');
}

function saveProfile(){
  if(!currentUser)return;
  var name=el('pf-name').value+' '+el('pf-sname').value;
  var email=el('pf-email').value,phone=el('pf-phone').value,role=el('pf-role').value;
  var av=(name[0]+((name.split(' ')[1]||'')[0]||'')).toUpperCase();
  currentUser=Object.assign({},currentUser,{name:name,email:email,phone:phone,role:role,avatar:av});
  ss(currentUser);updateUI();alert('Profil saqlandi!');
}

function togTask(e){
  e.classList.toggle('done');
  e.nextElementSibling.querySelector('.task-name').classList.toggle('done');
}

/* ---- CHART ---- */
function initChart(){
  if(chartInst)return;
  var c=el('actChart');if(!c)return;
  chartInst=new Chart(c.getContext('2d'),{
    type:'bar',
    data:{labels:['Du','Se','Ch','Pa','Ju','Sh','Ya'],
      datasets:[
        {label:'Faol ishchilar',data:[95,88,102,97,110,85,78],backgroundColor:'rgba(59,130,246,0.5)',borderColor:'#3b82f6',borderWidth:2,borderRadius:6},
        {label:'Bajarilgan',data:[12,19,15,22,18,9,7],backgroundColor:'rgba(139,92,246,0.4)',borderColor:'#8b5cf6',borderWidth:2,borderRadius:6}
      ]},
    options:{responsive:true,maintainAspectRatio:false,
      plugins:{legend:{labels:{color:'#94a3b8',font:{family:'Sora',size:12}}}},
      scales:{x:{grid:{color:'rgba(255,255,255,0.05)'},ticks:{color:'#64748b'}},y:{grid:{color:'rgba(255,255,255,0.05)'},ticks:{color:'#64748b'}}}}
  });
}

/* ---- BOOT ---- */
(function(){
  var saved=ls();
  if(saved){
    currentUser=saved;
    el('page-login').classList.remove('active');
    el('page-app').classList.add('active');
    updateUI();renderAll();setTimeout(initChart,100);
  }
})();
</script>
